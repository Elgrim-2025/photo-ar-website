{
  "name": "photo-ar-website",
  "compatibility_date": "2026-02-09",
  "main": "src/worker.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "AR_BUCKET",
      "bucket_name": "ar-uploads"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "AR_META",
      "id": "PLACEHOLDER_KV_ID"
    }
  ]
}
