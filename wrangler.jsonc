{
  "name": "photo-ar-website",
  "compatibility_date": "2026-02-09",
  "main": "src/worker.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "none"
  },
  "r2_buckets": [
    {
      "binding": "AR_BUCKET",
      "bucket_name": "ar-uploads"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "AR_META",
      "id": "98f8b6fb7a0e4d69b5f64fad00b75b63"
    }
  ]
}
